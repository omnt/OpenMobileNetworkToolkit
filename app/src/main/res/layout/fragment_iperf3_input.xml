<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/iperf3_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:layout_marginBottom="2dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/input_card"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="4dp"
            android:layout_weight="1"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="8dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iperf3_ip_layout"
                    style="@style/iperf3TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/iperf3_ip"
                        style="@style/iperf3TextInputEditText"
                        android:hint="IP Address"
                        android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iperf3_port_layout"
                    style="@style/iperf3TextInputLayout"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/iperf3_port"
                        style="@style/iperf3TextInputEditText"
                        android:hint="Port"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iperf3_bandwidth_layout"
                    style="@style/iperf3TextInputLayout"
                    app:suffixText="Mb">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/iperf3_bandwidth"
                        style="@style/iperf3TextInputEditText"
                        android:hint="Bandwidth"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iperf3_duration_layout"
                    style="@style/iperf3TextInputLayout"
                    app:suffixText="s">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/iperf3_duration"
                        style="@style/iperf3TextInputEditText"
                        android:hint="Duration"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iperf3_interval_layout"
                    style="@style/iperf3TextInputLayout"
                    app:suffixText="s">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/iperf3_interval"
                        style="@style/iperf3TextInputEditText"
                        android:hint="Interval"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iperf3_bytes_layout"
                    style="@style/iperf3TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/iperf3_bytes"
                        style="@style/iperf3TextInputEditText"
                        android:hint="Bytes"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iperf3_streams_layout"
                    style="@style/iperf3TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/iperf3_streams"
                        style="@style/iperf3TextInputEditText"
                        android:hint="Streams"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iperf3_cport_layout"
                    style="@style/iperf3TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/iperf3_cport"
                        style="@style/iperf3TextInputEditText"
                        android:hint="Client Port"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.4"
            android:orientation="vertical"
            android:weightSum="3"
            android:padding="4dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/iperf3_mode_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/iperf3_client_button"
                    style="@style/CustomUnifiedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Client" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/iperf3_server_button"
                    style="@style/CustomUnifiedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Server" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/iperf3_protocol_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/iperf3_tcp_button"
                    style="@style/CustomUnifiedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TCP" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/iperf3_udp_button"
                    style="@style/CustomUnifiedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="UDP" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/iperf3_direction_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/iperf3_download_button"
                    style="@style/CustomUnifiedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Download" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/iperf3_upload_button"
                    style="@style/CustomUnifiedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upload" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/iperf3_bidir_button"
                    style="@style/CustomUnifiedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BiDir" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>
            <com.google.android.material.button.MaterialButton
            android:id="@+id/iperf3_send"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/execute_iperf_command"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:paddingLeft="50dp"
            android:paddingRight="50dp"/>
        </LinearLayout>

    </LinearLayout>
    <FrameLayout
        android:id="@+id/standard_bottom_sheet"
        style="@style/Widget.Material3.BottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                android:id="@+id/drag_handle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/iperf3_influx_upload_button"
                android:layout_width="106dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_gravity="end|bottom"
                android:layout_marginStart="16dp"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="40dp"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="40dp"
                android:contentDescription="@string/upload"
                android:src="@drawable/ic_upload"
                android:visibility="invisible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/runners_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            </androidx.recyclerview.widget.RecyclerView>
        </LinearLayout>

    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>